GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS is NOT needed on Cloud Run (ADC is automatic).
# For local development, run: gcloud auth application-default login
FIREBASE_PROJECT_ID=your-firebase-project-id
ENVIRONMENT=development
FEEDBACK_SENDER_EMAIL=your-feedback-sender@gmail.com
FEEDBACK_SENDER_APP_PASSWORD=your-app-password
FEEDBACK_RECIPIENT_EMAIL=your-recipient@gmail.com
