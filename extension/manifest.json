{
  "manifest_version": 3,
  "name": "Axis",
  "version": "2.7.04",
  "description": "Voice-driven browser assistant powered by Gemini AI",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage",
    "identity",
    "sidePanel",
    "audio",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>",
    "chrome://*/*"
  ],
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "popup/pcm-processor.js",
        "popup/audio-player-worklet.js",
        "content/pcm-processor.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "key": ""
}